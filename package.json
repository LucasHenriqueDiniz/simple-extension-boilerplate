{
  "name": "chrome-extension-boilerplate-react-vite",
  "version": "0.5.0",
  "description": "chrome extension boilerplate",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite build --config vite.background.config.ts && vite build --config vite.content.config.ts",
    "create-extension": "node scripts/create-extension.js",
    "zip": "node scripts/zip.js"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.323",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react-swc": "^3.10.0",
    "autoprefixer": "^10.4.21",
    "fflate": "^0.8.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.6"
  },
  "engines": {
    "node": ">=22.15.1"
  }
}
