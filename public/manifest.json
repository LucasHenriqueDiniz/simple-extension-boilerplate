{
  "manifest_version": 3,
  "name": "__MSG_app_name__",
  "version": "1.0.0",
  "description": "__MSG_app_description__",
  "default_locale": "en",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [],
  "icons": {
    "128": "icons/icon.png"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["changelog.html", "changelog/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
